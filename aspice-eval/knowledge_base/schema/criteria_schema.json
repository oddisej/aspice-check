{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ASPICE Knowledge Base Criteria File",
  "description": "Schema for ASPICE process group criteria files with base practices, generic practices, and process outcomes from the PAM v4.0",
  "type": "object",
  "required": ["process_group", "processes"],
  "properties": {
    "process_group": {
      "type": "object",
      "required": ["code", "name"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z]{2,4}$" },
        "name": { "type": "string" }
      }
    },
    "processes": {
      "type": "array",
      "description": "List of processes in this process group",
      "items": {
        "type": "object",
        "required": ["process_id", "process_name", "process_purpose", "process_outcomes", "base_practices", "output_information_items"],
        "properties": {
          "process_id": { "type": "string" },
          "process_name": { "type": "string" },
          "process_purpose": { "type": "string" },
          "process_outcomes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description"],
              "properties": {
                "id": { "type": "integer", "minimum": 1 },
                "description": { "type": "string" }
              }
            },
            "minItems": 1
          },
          "base_practices": {
            "type": "array",
            "description": "Base practices for capability level 1 (PA 1.1) - process-specific",
            "items": {
              "type": "object",
              "required": ["bp_id", "title", "description"],
              "properties": {
                "bp_id": { "type": "string", "pattern": "^BP[0-9]+$" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "notes": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "maps_to_outcomes": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "description": "Which process outcome IDs this BP maps to"
                }
              }
            },
            "minItems": 1
          },
          "output_information_items": {
            "type": "array",
            "description": "Output information items produced by this process",
            "items": {
              "type": "object",
              "required": ["item_id", "name"],
              "properties": {
                "item_id": { "type": "string" },
                "name": { "type": "string" },
                "maps_to_outcomes": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              }
            },
            "minItems": 1
          },
          "evaluation_guidance": {
            "type": "string",
            "description": "Additional guidance for evaluating this process at capability level 1"
          },
          "example_evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "generic_practices": {
      "type": "object",
      "description": "Generic practices for capability levels 2-5, applicable to all processes in this group",
      "properties": {
        "PA_2_1": { "$ref": "#/definitions/generic_practice_set" },
        "PA_2_2": { "$ref": "#/definitions/generic_practice_set" },
        "PA_3_1": { "$ref": "#/definitions/generic_practice_set" },
        "PA_3_2": { "$ref": "#/definitions/generic_practice_set" },
        "PA_4_1": { "$ref": "#/definitions/generic_practice_set" },
        "PA_4_2": { "$ref": "#/definitions/generic_practice_set" },
        "PA_5_1": { "$ref": "#/definitions/generic_practice_set" },
        "PA_5_2": { "$ref": "#/definitions/generic_practice_set" }
      }
    }
  },
  "definitions": {
    "generic_practice_set": {
      "type": "object",
      "required": ["process_attribute_id", "process_attribute_name", "capability_level", "practices"],
      "properties": {
        "process_attribute_id": { "type": "string", "pattern": "^PA \\d\\.\\d$" },
        "process_attribute_name": { "type": "string" },
        "capability_level": { "type": "integer", "minimum": 2, "maximum": 5 },
        "scope": { "type": "string" },
        "achievements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "integer" },
              "description": { "type": "string" }
            }
          }
        },
        "practices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gp_id", "title", "description"],
            "properties": {
              "gp_id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "notes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "maps_to_achievements": {
                "type": "array",
                "items": { "type": "integer" }
              }
            }
          },
          "minItems": 1
        },
        "output_information_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item_id", "name"],
            "properties": {
              "item_id": { "type": "string" },
              "name": { "type": "string" },
              "maps_to_achievements": {
                "type": "array",
                "items": { "type": "integer" }
              }
            }
          }
        },
        "evaluation_guidance": { "type": "string" },
        "example_evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
